{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.2",
        "arrilot/laravel-widgets": "3.14.0",
        "barryvdh/laravel-dompdf": "^3.0",
        "carbonphp/carbon-doctrine-types": "^2.0",
        "cviebrock/eloquent-sluggable": "^12.0",
        "diglactic/laravel-breadcrumbs": "^10.0",
        "doctrine/dbal": "^3.7",
        "dyrynda/laravel-model-uuid": "^8.2",
        "giggsey/libphonenumber-for-php": "^9.0",
        "guzzlehttp/guzzle": "^7.5",
        "intervention/image": "2.4.2",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.9",
        "league/flysystem": "^3.0",
        "mcamara/laravel-localization": "^2.3",
        "nztim/mailchimp": "^3.11",
        "qcod/laravel-app-settings": "^1.7",
        "rap2hpoutre/laravel-log-viewer": "^2.0",
        "spatie/laravel-image-optimizer": "^1.6"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.2",
        "fakerphp/faker": "^1.24",
        "laravel/breeze": "^2.3",
        "mockery/mockery": "^1.0",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "files": [
          "app/Http/helpers.php"
        ],
        "classmap": [
            "database/seeds",
            "database/factories"
        ],
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
            ]
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "kylekatarnls/update-helper": true
        },
        "audit": {
            "block-insecure": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
